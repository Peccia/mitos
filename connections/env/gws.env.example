# Google Workspace MCP Server — environment template
#
# CONFIG CONTRACT SOURCE: https://github.com/taylorwilsdon/google_workspace_mcp
# This template mirrors the variables that upstream README documents; consult it
# before adding/changing keys — never invent variables. The full contract includes
# many more optional vars (OAuth 2.1 multi-user, GCS credential store, service
# accounts, …) that this installation doesn't use.
#
# OAuth credentials: upstream accepts either GOOGLE_OAUTH_CLIENT_ID[/SECRET] env vars
# or a client_secret.json file. THIS installation uses the file (see
# docs/google-workspace-mcp-setup.md), so this env stays secret-free by design.
# If you ever switch to env-based credentials, put them ONLY in `.local/gws.env`.
#
# Copy the values you need into `.local/gws.env` (gitignored). The compiler merges
# that overlay over this template at deploy time. NEVER put real secrets in this file.

# Streamable-HTTP mode: the server runs an HTTP endpoint on this port
WORKSPACE_MCP_TRANSPORT=streamable-http
WORKSPACE_MCP_PORT=8000
PORT=8000

# Allow insecure HTTP redirect for local loopback authentication
OAUTHLIB_INSECURE_TRANSPORT=1

# Default user email for single-user authentication
USER_GOOGLE_EMAIL=user@example.com

# Tool tier: core (essential tools), extended, or complete
WORKSPACE_MCP_TOOL_TIER=core

# Bind to all interfaces inside the container so Docker port mapping works
WORKSPACE_MCP_HOST=0.0.0.0

# Optional: restrict which tool groups load (comma-separated). Leave unset for tier default.
# WORKSPACE_MCP_TOOLS=gmail,drive,calendar
